{
  "version": "v1",
  "conventions": [
    {
      "name": "root-entry-exports",
      "paths": "src/index.ts",
      "must": {
        "export": ["govern", "createGovernedToolkit", "caller", "trusted", "always", "never"],
        "exportTypes": ["TrustedContext", "ExecutionContext", "GovernedToolSpec"]
      }
    },
    {
      "name": "errors-entry-exports",
      "paths": "src/errors.ts",
      "must": {
        "export": [
          "GovernanceError",
          "MissingContextError",
          "AccessDeniedError",
          "ScopeViolationError",
          "AuthorizationDeniedError",
          "GovernanceConfigError",
          "ApprovalPendingError",
          "ApprovalDeniedError",
          "IdempotencyConflictError",
          "isGovernanceError",
          "isGovernanceDenial",
          "isApprovalPending"
        ],
        "exportTypes": ["GovernanceErrorCode"]
      }
    },
    {
      "name": "audit-entry-exports",
      "paths": "src/audit.ts",
      "must": {
        "export": ["hashEntry", "verifyChain", "HashChainAuditLog", "InMemoryAuditLog"]
      }
    },
    {
      "name": "adapters-entry-exports",
      "paths": "src/adapters.ts",
      "must": {
        "export": [
          "defaultRbac",
          "autoApprove",
          "InMemoryIdempotencyStore",
          "scopeAllowed",
          "normalizeScopes",
          "deniedScopes",
          "hostContextResolver",
          "toFlueTool",
          "redactFields",
          "textRedactor",
          "composeRedactors",
          "defaultRedactor",
          "identityRedactor"
        ]
      }
    },
    {
      "name": "testing-entry-exports",
      "paths": "src/testing.ts",
      "must": { "export": ["InMemoryAuditLog", "InMemoryIdempotencyStore"] }
    }
  ]
}
