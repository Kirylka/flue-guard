{
  "name": "flue-guard",
  "version": "0.1.0",
  "description": "In-process authorization and tamper-evident audit for Flue agent tools — stop an agent acting on the wrong resource, twice, or unrecorded.",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "flue",
    "ai-agents",
    "agent-tools",
    "authorization",
    "tool-authorization",
    "audit-log",
    "tamper-evident",
    "idempotency",
    "governance",
    "prompt-injection"
  ],
  "author": "Kirylka",
  "homepage": "https://kirylka.github.io/flue-guard/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Kirylka/flue-guard.git"
  },
  "bugs": {
    "url": "https://github.com/Kirylka/flue-guard/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./audit": {
      "types": "./dist/src/audit.d.ts",
      "import": "./dist/src/audit.js"
    },
    "./adapters": {
      "types": "./dist/src/adapters.d.ts",
      "import": "./dist/src/adapters.js"
    },
    "./testing": {
      "types": "./dist/src/testing.d.ts",
      "import": "./dist/src/testing.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/src",
    "src",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22.19"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "konsistent": "konsistent",
    "check": "npm run typecheck && npm run lint && npm run konsistent",
    "test": "npm run build && node --test \"dist/test/**/*.test.js\"",
    "example": "npm run build && node dist/examples/support-agent.js",
    "spike": "npm run build && node scripts/live-faux-spike.mjs",
    "prepack": "npm run build",
    "prepublishOnly": "npm run build && npm test"
  },
  "peerDependencies": {
    "@flue/runtime": ">=1.0.0-beta.9 <1.0.0",
    "valibot": "^1.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@flue/runtime": "^1.0.0-beta.9",
    "@types/node": "^22.0.0",
    "eslint": "^10.6.0",
    "konsistent": "1.0.0-beta.1",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.62.1",
    "valibot": "^1.4.1"
  }
}
